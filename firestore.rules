rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} { allow read, write: if false; }

    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }

    function isValidTranslation(data) {
      return data.keys().hasAll(['originalText', 'translatedText', 'targetLanguage', 'createdAt']) 
             && data.keys().size() == 4
             && data.createdAt == request.time;
    }

    match /translations/{translationId} {
      allow get: if isValidId(translationId);
      allow create: if isValidId(translationId) && isValidTranslation(incoming());
    }
  }
}
