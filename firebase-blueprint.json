{
  "entities": {
    "Translation": {
      "title": "Translation",
      "description": "Cached translations to avoid redundant Gemini API calls.",
      "type": "object",
      "properties": {
        "originalText": { "type": "string" },
        "translatedText": { "type": "string" },
        "targetLanguage": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["originalText", "translatedText", "targetLanguage", "createdAt"]
    }
  },
  "firestore": {
    "/translations/{translationId}": {
      "schema": "Translation",
      "description": "Collection of cached translations."
    }
  }
}
